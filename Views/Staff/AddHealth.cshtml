@using ElderCareApp.Dto
@model AddHealthDto

<div class="container mt-4">
    <h3>Add Health Record</h3>
    <hr />

    <div asp-validation-summary="All" class="text-danger"></div>

    <form asp-action="AddHealth" method="post">
        <input type="hidden" asp-for="ElderId" />

        <div class="form-group mb-3">
            <label asp-for="HeartRate">Heart Rate (bpm)</label>
            <input asp-for="HeartRate" class="form-control" type="number" />
            <span asp-validation-for="HeartRate" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="BloodPressure">Blood Pressure (e.g., 120/80)</label>
            <input asp-for="BloodPressure" class="form-control" />
            <span asp-validation-for="BloodPressure" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Notes">Observations/Notes</label>
            <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Notes" class="text-danger"></span>
        </div>

        <div class="mt-3">
            <button type="submit" class="btn btn-success">Save Health Record</button>
            <a asp-action="Dashboard" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>